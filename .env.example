# =============================================================================
# VANTA OS — Environment Variables
# Copy to .env and fill in real values. NEVER commit the real .env.
#
# RENDER INSTRUCTIONS:
# - Do NOT create a .env file on Render. Instead, add all variables in the
#   Render Dashboard → your service → Environment tab.
# - DATABASE_URL and REDIS_URL are auto-filled by Render's blueprint.
# - All other variables must be added manually.
# =============================================================================

# --- App Environment ---
NODE_ENV=production
APP_ENV=production
APP_URL=REPLACE_WITH_YOUR_RENDER_URL
PORT=10000

# --- Shopify App Credentials ---
SHOPIFY_APP_URL=REPLACE_WITH_YOUR_RENDER_URL
SHOPIFY_API_KEY=REPLACE_WITH_YOUR_SHOPIFY_API_KEY
SHOPIFY_API_SECRET=REPLACE_WITH_YOUR_SHOPIFY_API_SECRET
SHOPIFY_APP_HANDLE=vanta-os
SHOPIFY_API_VERSION=2025-04
SHOPIFY_APP_SCOPES=read_products,write_products,read_inventory,write_inventory,read_locations,read_collections,write_collections,read_metafields,write_metafields,read_themes,read_orders,read_customers,read_price_rules,read_discounts,read_shop_locales,read_markets

# --- Database (auto-filled by Render blueprint) ---
DATABASE_URL=REPLACE_WITH_RENDER_POSTGRES_URL
DIRECT_URL=REPLACE_WITH_RENDER_POSTGRES_URL

# --- Redis (auto-filled by Render blueprint) ---
REDIS_URL=REPLACE_WITH_RENDER_REDIS_URL

# --- Google Gemini API ---
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash-exp

# --- Encryption (REQUIRED — generate with: openssl rand -base64 32) ---
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64_KEY

# --- Encryption Salt (REQUIRED — generate with: openssl rand -hex 16) ---
ENCRYPTION_SALT=REPLACE_WITH_32_BYTE_HEX_SALT

# --- Vault Salt (REQUIRED — generate with: openssl rand -hex 16) ---
VAULT_SALT=REPLACE_WITH_32_BYTE_HEX_SALT

# --- Internal Secrets (REQUIRED — generate with: openssl rand -hex 32) ---
INTERNAL_DOCS_SECRET=REPLACE_WITH_RANDOM_STRING
AGENCY_SECRET=REPLACE_WITH_RANDOM_STRING

# --- Email Provider (optional) ---
RESEND_API_KEY=
EMAIL_FROM="VANTA OS <noreply@yourdomain.com>"
EMAIL_SUPPORT=support@yourdomain.com

# --- Error Tracking (optional) ---
SENTRY_DSN=

# --- Feature flags ---
WHITELABEL_MODE=false
