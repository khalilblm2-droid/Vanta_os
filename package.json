{
  "name": "vanta-os",
  "private": true,
  "version": "1.0.0",
  "description": "VANTA OS — Shopify Embedded AI Agent App",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "remix vite:dev",
    "dev:shopify": "shopify app dev",
    "dev:worker": "tsx watch --tsconfig tsconfig.worker.json app/worker/index.ts",
    "build": "remix vite:build",
    "build:worker": "tsc -p tsconfig.worker.json && esbuild app/worker/index.ts --bundle --platform=node --format=esm --outfile=dist/worker/index.js --external:@prisma/client --external:better-sqlite3",
    "start": "node -r dotenv/config node_modules/@remix-run/serve/dist/cli.js ./build/server/index.js",
    "start:worker": "tsx app/worker/index.ts",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:reset": "prisma migrate reset --force",
    "generate": "prisma generate",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "backup:db": "tsx scripts/backup-db.ts",
    "restore:db": "tsx scripts/restore-db.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "tsc --noEmit -p tsconfig.worker.json",
    "deploy": "shopify app deploy",
    "deploy:db": "prisma migrate deploy && tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "check": "tsx scripts/check-setup.ts",
    "sync-toml": "tsx scripts/sync-toml.ts",
    "generate-icons": "tsx scripts/generate-icons.ts",
    "prebuild": "npm run generate-icons || echo 'skip icons'",
    "predeploy": "npm run sync-toml && npm run check"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "5.22.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@remix-run/node": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "@remix-run/serve": "^2.15.0",
    "resend": "^4.0.1",
    "@sentry/node": "^8.47.0",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^13.9.0",
    "@shopify/polaris-icons": "^9.2.0",
    "@shopify/shopify-api": "^11.11.0",
    "@shopify/shopify-app-remix": "^3.7.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.1.6",
    "bullmq": "^5.34.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "framer-motion": "^11.15.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.4.2",
    "isbot": "^4.4.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^9.0.1",
    "react-joyride": "^2.9.3",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@remix-run/dev": "^2.15.0",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8"
  },
  "sideEffects": false
}
